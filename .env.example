# Copy to .env and fill in. Never commit your real .env.

# --- Required ---

# TorBox API key: TorBox dashboard -> Settings -> API
TORBOX_API_KEY=

# Login for the admin UI (HTTP Basic Auth)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Full public URL where this app is reachable. Used to build the feed, stream,
# and image URLs that go into your podcast app. No trailing slash needed.
PUBLIC_URL=https://podcast.example.com

# --- Optional ---

# Free TMDB API key for posters + search metadata.
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Base URL of a Comet instance for the search-first flow (find torrents already
# cached on TorBox by title/episode). Leave empty to add only from your TorBox
# library or local uploads.
COMET_URL=
